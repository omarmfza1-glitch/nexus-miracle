# ===========================================
# Nexus Miracle - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=Nexus Miracle
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ===========================================
# Telnyx Configuration
# ===========================================
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_API_SECRET=your_telnyx_api_secret_here
TELNYX_CONNECTION_ID=your_telnyx_connection_id_here
TELNYX_PHONE_NUMBER=+966xxxxxxxxx
TELNYX_WEBHOOK_URL=https://your-domain.com/api/telephony/webhook

# ===========================================
# ElevenLabs Configuration
# ===========================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice IDs for dual-voice support
ELEVENLABS_VOICE_SARA=your_sara_voice_id_here
ELEVENLABS_VOICE_NEXUS=your_nexus_voice_id_here

# TTS Settings
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# ===========================================
# Google Gemini Configuration
# ===========================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ===========================================
# Audio Processing Settings
# ===========================================
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=500

# ===========================================
# Performance Settings
# ===========================================
MAX_CONCURRENT_CALLS=100
RESPONSE_TIMEOUT_MS=800
